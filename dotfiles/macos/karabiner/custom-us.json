/*
Karabiner-Elements configuration for US-recognized-JIS and US layout keyboards.

This configuration is for two purposes:
- 1. Restore some default JIS keyboard behaviors (e.g. `ろ` -> `_`)
- 2. Customize some default US keyboard behaviors (e.g. CapsLock -> Control)

## 1. Restore some default JIS keyboard behaviors

I use Macbook when I'm out and it has a JIS layout keyboard.
Although I slightly prefer the US layout than JIS, I have been using the JIS layout Macbook for years. 
The reason is it has more keys than the US layout. Examples:
- An underscore key. I really like it because underscore is frequently used in programming.
- Two IME (language) switch keys on either side of the Space bar.
  Once you get used to this, you can't live without these keys anymore. Typing with your thumbs is so effortless,
  and I really feel it’s a waste that the space bar takes up so much room on a standard US keyboard.

On the other hand, the JIS layout has some downsides compared to the US layout. Examples:
- Weird keys for single and double quotes (`Shift-7` and `Shfit-2` respectively).
- Shift is required to emit `=` (Shift-minus).

The best way I've found so far is to use a JIS keyboard physically but have the PC recognize it as the US layout.
This way, I can enjoy the intuitive US key mapping while using additional physical keys of the JIS layout. This is nice.
But now the PC cannot recognize keys that exist only in JIS layout, so I need to remap them to their original JIS functions.

## 2. Customize some default US keyboard behaviors

At home, I use Dygma Raise 2. It is the US layout but I love it because it splits the space bar into 4 keys.
It is a programmable keyboard so I can map those keys to IME switch keys or any arbitrary keys.
This is really nice but it sill lacks some keys that a standard JIS keyboard has.
And some remapping cannot be achieved with the keyboard's builtin remapping firmware.
Therefore I customize it with Karabiner-Elements.
*/

{
  "title": "Custom US",
  "description": "Improve US / Use JIS as US",
  // Each mapping description has prefixes like `[US]` and/or `[JIS]`.
  // - [US]:

  "rules": [
    {
      "description": "[US] Colon<->Semicolon and Caplock->Ctrl",
      "manipulators": [
        // Semicolon -> Colon (Shift-Semicolon)
        {
          "from": {
            "key_code": "semicolon"
          },
          "to": [
            {
              "key_code": "semicolon",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic",
          "conditions": [
            {
              "type": "keyboard_type_if",
              "keyboard_types": ["ansi"]
            }
          ]
        },
        // Colon (Shift-Semicolon) -> Semicolon
        {
          "from": {
            "key_code": "semicolon",
            "modifiers": {
              "mandatory": ["left_shift"]
            }
          },
          "to": [
            {
              "key_code": "semicolon"
            }
          ],
          "type": "basic",
          "conditions": [
            {
              "type": "keyboard_type_if",
              "keyboard_types": ["ansi"]
            }
          ]
        },
        // CapsLock -> Control
        {
          "from": {
            "key_code": "caps_lock"
          },
          "to": [
            {
              "key_code": "left_control"
            }
          ],
          "type": "basic",
          "conditions": [
            {
              "type": "keyboard_type_if",
              "keyboard_types": ["ansi"]
            }
          ]
        }
      ]
    },
    {
      // The tilde key is difficult to press or lacked on some US keyboards.
      "description": "[US][JIS] Shift+Backspace->Tilde",
      "manipulators": [
        {
          "description": "[US] Shift+Backspace",
          "from": {
            "key_code": "delete_or_backspace",
            "modifiers": {
              "mandatory": ["left_shift"]
            }
          },
          "to": [
            {
              "key_code": "grave_accent_and_tilde",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic",
          "conditions": [
            {
              "type": "keyboard_type_if",
              "keyboard_types": ["ansi"]
            }
          ]
        },
        {
          "description": "[JIS] Shift+¥->Tilde",
          "from": {
            "key_code": "international3", // The `¥` key to the left of Backspace
            "modifiers": {
              "optional": ["left_shift", "right_shift"]
            }
          },
          "to": [
            {
              "key_code": "grave_accent_and_tilde",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic",
          "conditions": [
            {
              "type": "keyboard_type_if",
              "keyboard_types": ["ansi"]
            }
          ]
        }
      ]
    },
    {
      "description": "[US][JIS] Underscore and Backquote",
      "manipulators": [
        // I configure my Dygma Raise keyboard to emit `function 22` on tap of the right Shift key.
        // I want to input `_` without Shift like JIS keyboard can.
        {
          "description": "[US] f22->underscore",
          "from": {
            "key_code": "f22"
          },
          "to": [
            {
              "key_code": "hyphen",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic"
        },
        // I also want to emit "`" (backtick / backquote) with Shift-"_".
        // The default position of the backtick in US layout is too far.
        {
          "description": "[US] f22+Shift->backquote",
          "from": {
            "key_code": "f22",
            "modifiers": {
              "mandatory": ["left_shift"]
            }
          },
          "to": [
            {
              "key_code": "grave_accent_and_tilde"
            }
          ],
          "type": "basic"
        },
        {
          "description": "[JIS] ろ->underscore",
          "from": {
            "key_code": "international1"
          },
          "to": [
            {
              "key_code": "hyphen",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic",
          "conditions": [
            {
              "type": "keyboard_type_if",
              "keyboard_types": ["ansi"]
            }
          ]
        },
        {
          "description": "[JIS] ろ+Shift->backquote",
          "from": {
            "key_code": "international1",
            "modifiers": {
              "mandatory": ["left_shift"]
            }
          },
          "to": [
            {
              "key_code": "grave_accent_and_tilde"
            }
          ],
          "type": "basic",
          "conditions": [
            {
              "type": "keyboard_type_if",
              "keyboard_types": ["ansi"]
            }
          ]
        },
        {
          "description": "Shift+Hyphen->Bar",
          "from": {
            "key_code": "hyphen",
            "modifiers": {
              "mandatory": ["left_shift"]
            }
          },
          "to": [
            {
              "key_code": "backslash",
              "modifiers": "left_shift"
            }
          ],
          "type": "basic",
          "conditions": [
            {
              "type": "keyboard_type_if",
              "keyboard_types": ["ansi"]
            }
          ]
        }
      ]
    },
    {
      "description": "[US][JIS] Mini layer",
      "manipulators": [
        {
          "from": {
            "key_code": "r",
            "modifiers": {
              "mandatory": ["right_command"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "tab",
              "modifiers": ["left_shift", "left_control"]
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "t",
            "modifiers": {
              "mandatory": ["right_command"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "tab",
              "modifiers": ["left_control"]
            }
          ],
          "type": "basic"
        },

        {
          "from": {
            "key_code": "h",
            "modifiers": {
              "mandatory": ["right_command"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_arrow"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "j",
            "modifiers": {
              "mandatory": ["right_command"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "down_arrow"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "k",
            "modifiers": {
              "mandatory": ["right_command"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "up_arrow"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "l",
            "modifiers": {
              "mandatory": ["right_command"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "right_arrow"
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "[experimental] dual kana key",
      "manipulators": [
        {
          "description": "f20->Kana (for Dygma)",
          "type": "basic",
          "from": {
            "key_code": "f20"
          },
          "to": [{ "key_code": "japanese_kana" }]
        },

        // {
        //   "description": "kana -> alt",
        //   "type": "basic",
        //   "from": {
        //     "key_code": "japanese_kana",
        //     "modifiers": { "optional": ["any"] }
        //   },
        //   "to": [{ "key_code": "right_option" }]
        // },
        // {
        //   "description": "right_option+eisuu -> kana",
        //   "type": "basic",
        //   "from": {
        //     "key_code": "japanese_eisuu",
        //     "modifiers": { "mandatory": ["right_option"] }
        //   },
        //   "to": [{ "key_code": "japanese_kana" }]
        // }

        {
          "description": "kana -> kana / alt (Mac)",
          "type": "basic",
          "from": {
            "key_code": "japanese_kana",
            "modifiers": { "optional": ["any"] }
          },
          "to": [{ "key_code": "right_option", "lazy": true }],
          "to_if_alone": [{ "key_code": "japanese_kana" }],
          "parameters": {
            "basic.to_if_alone_timeout_milliseconds": 200
          }
        }
        // {
        //   "description": "alt->f5",
        //   "type": "basic",
        //   "from": {
        //     "key_code": "left_option"
        //   },
        //   "to": [{ "key_code": "f5" }]
        // }
      ]
    }
  ]
}
