{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(.local/claude/**)",
      "Write(.local/claude/**)",
      "Edit(.local/claude/**)",
      "Bash(echo:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(cat:*)",
      "Bash(bat:*)",
      "Bash(prettier:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git pull:*)",
      "Bash(git -c color.ui=never add:*)",
      "Bash(git -c color.ui=never branch:*)",
      "Bash(git -c color.ui=never commit:*)",
      "Bash(git -c color.ui=never status:*)",
      "Bash(git -c color.ui=never log:*)",
      "Bash(git -c color.ui=never diff:*)",
      "Bash(git -c color.ui=never show:*)",
      "Bash(git -c color.ui=never checkout:*)",
      "Bash(git -c color.ui=never fetch:*)",
      "Bash(git -c color.ui=never stash:*)",
      "Bash(git -c color.ui=never pull:*)",
      "Bash(tmux list-panes:*)",
      "Bash(tmux display-message:*)",
      "Bash(tmux capture-pane:*)"
    ],
    "deny": [
      "Read(.local/human/**)",
      "Read(//)",
      "Read(~/)",
      "Edit(//)",
      "Edit(~/)",
      "Write(//)",
      "Write(~/)"
    ]
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "_claude_hook"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "_claude_hook"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "_claude_hook"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.dotfiles/dotfiles/claude/statusline.sh"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Working"
    ]
  },
  "effortLevel": "medium"
}
