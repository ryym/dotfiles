#!/usr/bin/env bash

# Display a desktop notification when the execution of the specified command is complete.
# Usage: notif sleep 3

source "$DOTPATH/lib/vitalize.sh"

shopt -s expand_aliases
source "$DOTPATH/dotfiles/shell/aliases"
test -f "$HOME/aliases.local" && source "$HOME/aliases.local"

# Register job status if tmux is running.
tmuxx job-status set 'running'

printf -v escaped '%q ' "$@"
eval "$escaped"
exit_code=$?

tmuxx job-status set 'done'

prefix=$(test $exit_code -eq 0 && echo 'ok:' || echo 'ERR:')
cmds=($@)

case $(ostype) in
    macos )
        osascript -e "display notification \"${cmds[*]}\" with title \"$prefix ${cmds[0]}\""
        ;;

    arch | fedora )
        notify-send "$prefix ${cmds[*]}"
        ;;

    * )
        echo "OS not supported" && exit 1
        ;;
esac

# Wait for the user's confirmation.
exit_mark=$(test $exit_code -eq 0 && echo "\x1b[32m✓\x1b[0m" || echo "\x1b[31m!\x1b[0m")
printf "$exit_mark exited with $exit_code. Press any key to quit:"
read -n 1 -s -r
echo

tmuxx job-status clear

exit $exit_code
